{
  "name": "mongo-pilot",
  "version": "0.2.7",
  "private": true,
  "description": "A MongoDB desktop workspace with an OpenCode copilot.",
  "author": "Vikings Studio",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && npm run lint && electron-vite build",
    "lint": "biome lint . --error-on-warnings",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:bson": "tsx scripts/bson-format-smoke.ts",
    "test:aggregation": "tsx scripts/aggregation-pipeline-smoke.ts",
    "test:mcp": "tsx scripts/mcp-smoke.ts",
    "test:namespaces": "tsx scripts/namespace-visibility-smoke.ts",
    "test:schema": "tsx scripts/schema-analysis-smoke.ts",
    "test:shell": "tsx scripts/shell-runtime-smoke.ts",
    "test:visualization": "tsx scripts/visualization-smoke.ts",
    "test:visualization-storage": "tsx scripts/visualization-storage-smoke.ts",
    "test:write-approval": "tsx scripts/write-approval-smoke.ts",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --universal --publish never",
    "dist:windows": "npm run build && electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mongosh/node-runtime-worker-thread": "^5.2.13",
    "@opencode-ai/sdk": "1.18.2",
    "@phosphor-icons/react": "2.1.10",
    "electron-updater": "^6.8.9",
    "express": "^5.1.0",
    "mongodb": "7.5.0",
    "opencode-ai": "1.18.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "web-worker": "^1.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "4.3.3",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.3",
    "tsx": "^4.20.6",
    "typescript": "7.0.2",
    "vite": "7.3.6"
  },
  "build": {
    "appId": "com.mongopilot.desktop",
    "productName": "Mongo Pilot",
    "artifactName": "Mongo-Pilot-${version}-${os}-${arch}.${ext}",
    "icon": "resources/icon.png",
    "files": [
      "out/**/*",
      "resources/icon.png",
      "package.json",
      "!node_modules/opencode-ai{,/**/*}",
      "!node_modules/opencode-darwin-*{,/**/*}",
      "!node_modules/opencode-linux-*{,/**/*}",
      "!node_modules/opencode-windows-*{,/**/*}"
    ],
    "asarUnpack": [
      "node_modules/@mongosh/node-runtime-worker-thread/**/*",
      "node_modules/@mongosh/shell-bson/**/*",
      "node_modules/system-ca/**/*",
      "node_modules/interruptor/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Vikings-Studio",
        "repo": "mongopilot",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "x64ArchFiles": "Contents/Resources/opencode/**",
      "target": [
        "dmg",
        "zip"
      ],
      "extraResources": [
        {
          "from": "build/opencode/opencode-arm64",
          "to": "opencode/opencode-arm64"
        },
        {
          "from": "build/opencode/opencode-x64",
          "to": "opencode/opencode-x64"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "node_modules/opencode-ai/bin/opencode.exe",
          "to": "opencode/opencode.exe"
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": "AppImage",
      "extraResources": [
        {
          "from": "node_modules/opencode-ai/bin/opencode.exe",
          "to": "opencode/opencode"
        }
      ]
    }
  }
}
